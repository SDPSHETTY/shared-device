<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ZebraEsperBridge" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/auth_accent</item>
        <item name="colorSecondary">@color/seed_dark</item>
        <item name="colorSurface">@color/auth_panel</item>
        <item name="colorOnSurface">@color/auth_text_primary</item>
        <item name="colorOutline">@color/auth_panel_stroke</item>
        <item name="android:windowBackground">@drawable/bg_auth_screen</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <style name="Widget.AuthApp.InputLayout" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="boxBackgroundColor">@color/auth_input_fill</item>
        <item name="boxStrokeColor">@color/auth_input_stroke</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="hintTextColor">@color/auth_input_hint</item>
        <item name="android:textColorHint">@color/auth_input_hint</item>
        <item name="endIconTint">@color/auth_text_secondary</item>
    </style>

    <style name="Widget.AuthApp.InputLayout.Dropdown" parent="Widget.Material3.TextInputLayout.FilledBox.ExposedDropdownMenu">
        <item name="boxBackgroundColor">@color/auth_input_fill</item>
        <item name="boxStrokeColor">@color/auth_input_stroke</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="hintTextColor">@color/auth_input_hint</item>
        <item name="android:textColorHint">@color/auth_input_hint</item>
        <item name="endIconTint">@color/auth_text_secondary</item>
        <item name="simpleItemSelectedColor">@color/auth_accent_soft</item>
        <item name="simpleItemSelectedRippleColor">@color/auth_accent_soft</item>
    </style>

    <style name="Widget.AuthApp.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/auth_button_primary</item>
        <item name="android:textColor">@color/auth_button_primary_text</item>
        <item name="cornerRadius">28dp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="elevation">0dp</item>
        <item name="rippleColor">@color/auth_accent_soft</item>
    </style>

    <style name="Widget.AuthApp.Button.Secondary" parent="Widget.Material3.Button.TonalButton">
        <item name="backgroundTint">@color/auth_button_secondary</item>
        <item name="android:textColor">@color/auth_button_secondary_text</item>
        <item name="cornerRadius">28dp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="elevation">0dp</item>
        <item name="rippleColor">@color/auth_accent_soft</item>
    </style>

    <style name="Widget.AuthApp.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/auth_button_outline</item>
        <item name="strokeWidth">2dp</item>
        <item name="android:textColor">@color/auth_button_outline_text</item>
        <item name="cornerRadius">28dp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="rippleColor">@color/auth_accent_soft</item>
    </style>
</resources>
