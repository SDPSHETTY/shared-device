<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:gravity="center">
        <shape android:shape="oval">
            <size android:width="72dp" android:height="72dp" />
            <solid android:color="#FFFFFFFF" />
        </shape>
    </item>
    <item android:gravity="center_horizontal|top" android:top="23dp">
        <shape android:shape="rectangle">
            <size android:width="26dp" android:height="8dp" />
            <corners android:radius="4dp" />
            <solid android:color="@color/icon_bg" />
        </shape>
    </item>
    <item android:gravity="center">
        <shape android:shape="rectangle">
            <size android:width="30dp" android:height="36dp" />
            <corners android:radius="6dp" />
            <solid android:color="@color/icon_bg" />
        </shape>
    </item>
</layer-list>
