<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:gravity="center">
        <shape android:shape="oval">
            <size android:width="72dp" android:height="72dp" />
            <solid android:color="#FFFFFFFF" />
        </shape>
    </item>
    <item android:gravity="center_horizontal|top" android:top="24dp">
        <shape android:shape="rectangle">
            <size android:width="20dp" android:height="10dp" />
            <corners android:radius="5dp" />
            <solid android:color="@color/icon_bg" />
        </shape>
    </item>
    <item android:gravity="center">
        <shape android:shape="rectangle">
            <size android:width="34dp" android:height="26dp" />
            <corners android:radius="8dp" />
            <solid android:color="@color/icon_bg" />
        </shape>
    </item>
</layer-list>
